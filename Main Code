#include <iostream>
#include <fstream>
#include <vector>
#include <string>
#include <cctype>
using namespace std;

// struct groups related data into one object
struct User {
    string username, password, role;
};

struct LeavePass {
    string name, date, timeout, timein, reason, status;
};

// vectorr stores multiple users
vector<User> users;
vector<LeavePass> records;

// Pang Validate
string getNonEmptyInput(string prompt) {
    string input;
    do {
        cout << prompt;
        getline(cin, input);
        if (input.empty()) {
            cout << "Input cannot be empty. Try again.\n";
        }
    } while (input.empty());
    return input;
}

int getValidChoice(int min, int max) {
    int choice;
    while (true) {
        cin >> choice;
        if (cin.fail() || choice < min || choice > max) {
            cin.clear();
            cin.ignore(1000, '\n');
            cout << "Invalid choice. Enter (" << min << "-" << max << "): ";
        } else {
            cin.ignore(1000, '\n');
            return choice;
        }
    }
}

string getValidRole() {
    string role;
    while (true) {
        cout << "Role (Dormer/Manager): ";
        cin >> role;
        if (role == "Dormer" || role == "Manager") {
            cin.ignore();
            return role;
        } else {
            cout << "Invalid role. Try again.\n";
        }
    }
}

bool isValidTime(string t) {
    return t.find(':') != string::npos;
}

bool isValidDate(string d) {
    // (MM/DD/YYYY = 10 characters)
    if (d.length() != 10) return false;

    
    if (d[2] != '/' || d[5] != '/') return false;

    
    for (int i = 0; i < d.length(); i++) {
        if (i == 2 || i == 5) continue;
        if (!isdigit(d[i])) return false;
    }

    // For extract values
    int month = stoi(d.substr(0, 2));
    int day   = stoi(d.substr(3, 2));
    int year  = stoi(d.substr(6, 4));

    if (month < 1 || month > 12) return false;
    if (day < 1 || day > 31) return false;
    if (year < 2000 || year > 2100) return false;

    return true;
}

// Mga file functions kinemerut
void loadUsers() {
    ifstream file("users.txt");
    User u;
    while (file >> u.username >> u.password >> u.role) {
        users.push_back(u);
    }
    file.close();
}

void saveUsers() {
    ofstream file("users.txt");
    for (auto &u : users) {
        file << u.username << " " << u.password << " " << u.role << endl;
    }
    file.close();
}

void loadRecords() {
    ifstream file("records.txt");
    LeavePass lp;
    while (getline(file, lp.name)) {
        getline(file, lp.date);
        getline(file, lp.timeout);
        getline(file, lp.timein);
        getline(file, lp.reason);
        getline(file, lp.status);
        records.push_back(lp);
    }
    file.close();
}

void saveRecords() {
    ofstream file("records.txt");
    for (auto &lp : records) {
        file << lp.name << endl
             << lp.date << endl
             << lp.timeout << endl
             << lp.timein << endl
             << lp.reason << endl
             << lp.status << endl;
    }
    file.close();
}

// Register
void registerUser() {
    User u;

    cout << "Enter username: ";
    cin >> u.username;

    cout << "Enter password: ";
    cin >> u.password;

    u.role = getValidRole();

    users.push_back(u);
    saveUsers();

    cout << "Registered successfully!\n";
}

// Login
int loginUser() {
    string username, password;

    cout << "Username: ";
    cin >> username;

    cout << "Password: ";
    cin >> password;

    for (int i = 0; i < users.size(); i++) {
        if (users[i].username == username &&
            users[i].password == password) {
            cin.ignore();
            return i;
        }
    }

    cout << "Invalid login!\n";
    return -1;
}

// Menu for dormer
void dormerMenu(string name) {
    int choice;
    do {
        cout << "\n--- Dormer Menu ---\n";
        cout << "1 Submit Leave\n2 View My Passes\n3 Search by Status\n4 Logout\nChoice: ";
        choice = getValidChoice(1, 4);

        if (choice == 1) {
            LeavePass lp;
            lp.name = name;

            do {
    lp.date = getNonEmptyInput("Date (MM/DD/YYYY): ");
    if (!isValidDate(lp.date)) {
        cout << "Invalid date format. Use MM/DD/YYYY\n";
    }
} while (!isValidDate(lp.date));

            do {
                lp.timeout = getNonEmptyInput("Time out (HH:MM): ");
                if (!isValidTime(lp.timeout))
                    cout << "Invalid format.\n";
            } while (!isValidTime(lp.timeout));

            do {
                lp.timein = getNonEmptyInput("Time in (HH:MM): ");
                if (!isValidTime(lp.timein))
                    cout << "Invalid format.\n";
            } while (!isValidTime(lp.timein));

            lp.reason = getNonEmptyInput("Reason: ");
            lp.status = "Pending";

            records.push_back(lp);
            saveRecords();

            cout << "Submitted successfully!\n";
        }

        else if (choice == 2) {
            cout << "\n--- Your Passes ---\n";
            for (auto &lp : records) {
                if (lp.name == name) {
                    cout << lp.date << " | " << lp.status << endl;
                }
            }
        }

        else if (choice == 3) {
            string status;
            cout << "Enter status (Pending/Approved/Rejected): ";
            cin >> status;

            for (auto &lp : records) {
                if (lp.name == name && lp.status == status) {
                    cout << lp.date << " | " << lp.status << endl;
                }
            }
        }

    } while (choice != 4);
}

// Menu for manager
void managerMenu() {
    int choice;
    do {
        cout << "\n--- Manager Menu ---\n";
        cout << "1 View All\n2 Approve/Reject\n3 Reports\n4 Search by Name\n5 Logout\nChoice: ";
        choice = getValidChoice(1, 5);

        if (choice == 1) {
            for (int i = 0; i < records.size(); i++) {
                cout << i+1 << ". " << records[i].name
                     << " | " << records[i].date
                     << " | " << records[i].status << endl;
            }
        }

        else if (choice == 2) {
            cout << "Enter number: ";
            int idx = getValidChoice(1, records.size());

            cout << "1 Approve / 2 Reject: ";
            int decision = getValidChoice(1, 2);

            records[idx-1].status = (decision == 1) ? "Approved" : "Rejected";
            saveRecords();

            cout << "Updated!\n";
        }

        // pang bilang ng mga pending, approved, and rejected na lppp
        else if (choice == 3) {
            int p=0,a=0,r=0;
            for (auto &lp : records) {
                if (lp.status=="Pending") p++;
                else if (lp.status=="Approved") a++;
                else r++;
            }
            cout << "Pending: " << p
                 << " Approved: " << a
                 << " Rejected: " << r << endl;
        }

        else if (choice == 4) {
            string name;
            cout << "Enter name: ";
            cin >> name;

            for (auto &lp : records) {
                if (lp.name == name) {
                    cout << lp.date << " | " << lp.status << endl;
                }
            }
        }

    } while (choice != 5);
}

// Main
int main() {
    loadUsers();
    loadRecords();

    int choice;
    do {
        cout << "\n--- MAIN MENU ---\n";
        cout << "1 Register\n2 Login\n3 Exit\nChoice: ";
        choice = getValidChoice(1, 3);

        if (choice == 1) registerUser();

        else if (choice == 2) {
            int userIndex = loginUser();
            if (userIndex != -1) {
                if (users[userIndex].role == "Dormer")
                    dormerMenu(users[userIndex].username);
                else
                    managerMenu();
            }
        }

    } while (choice != 3);

    return 0;
}
